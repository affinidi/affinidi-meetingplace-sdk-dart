  "fixed_sql": [
    {
      "name": "chat_items",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"chat_items\" (\"chat_id\" TEXT NOT NULL, \"message_id\" TEXT NOT NULL, \"value\" TEXT NULL, \"is_from_me\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_from_me\" IN (0, 1)), \"date_created\" TEXT NOT NULL, \"status\" INTEGER NOT NULL, \"type\" INTEGER NOT NULL, \"event_type\" TEXT NULL, \"concierge_type\" TEXT NULL, \"data\" TEXT NULL, \"sender_did\" TEXT NOT NULL, \"transport_id\" TEXT NULL, \"is_deleted\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_deleted\" IN (0, 1)), \"is_deleted_locally\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_deleted_locally\" IN (0, 1)), \"edited_at\" TEXT NULL, PRIMARY KEY (\"message_id\"));"
        }
      ]
    },
    {
      "name": "reactions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"reactions\" (\"message_id\" TEXT REFERENCES chat_items(message_id) ON DELETE CASCADE NOT NULL, \"value\" TEXT NOT NULL);"
        }
      ]
    },
    {
      "name": "attachments",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"attachments\" (\"message_id\" TEXT REFERENCES chat_items(message_id) ON DELETE CASCADE NOT NULL, \"attachment_id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"id\" TEXT NULL, \"description\" TEXT NULL, \"filename\" TEXT NULL, \"media_type\" TEXT NULL, \"format\" TEXT NULL, \"last_modified_time\" TEXT NULL, \"jws\" TEXT NULL, \"byte_count\" INTEGER NULL, \"hash\" TEXT NULL, \"base64\" TEXT NULL, \"json\" TEXT NULL, \"transport_id\" TEXT NULL, \"metadata\" TEXT NULL);"
        }
      ]
    },
    {
      "name": "attachments_links",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"attachments_links\" (\"attachment_id\" INTEGER REFERENCES attachments(attachment_id) ON DELETE CASCADE NOT NULL, \"url\" TEXT NOT NULL);"
        }
      ]
    }
